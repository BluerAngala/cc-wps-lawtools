# WPS 加载项开发最佳实践

## WPS API 核心概念

### 应用程序对象层次结构
```
Application (WPS应用程序)
├── Documents (文档集合)
│   └── Document (单个文档)
│       ├── Range (文档范围)
│       ├── Selection (选择区域)
│       └── Paragraphs (段落集合)
├── TaskPanes (任务窗格集合)
└── FileSystem (文件系统)
```

### 基础 API 使用模式

#### 1. 获取应用程序实例
```javascript
// 标准方式
const app = wps.WpsApplication()

// 错误检查
if (!app) {
  console.error('无法获取 WPS 应用程序实例')
  return
}
```

#### 2. 文档操作
```javascript
// 获取活动文档
const doc = app.ActiveDocument
if (!doc) {
  ElMessage.warning('请先打开一个文档')
  return
}

// 获取文档内容
const content = doc.Content.Text

// 获取选中文本
const selection = app.Selection
const selectedText = selection.Text
```

#### 3. 任务窗格管理
```javascript
// 创建任务窗格
const taskPane = app.CreateTaskPane('任务窗格标题', 'taskpane.html')
taskPane.Visible = true
taskPane.Width = 300

// 监听任务窗格事件
taskPane.AddApiEventListener('TaskPaneNavigate', (event) => {
  console.log('任务窗格导航:', event)
})
```

## 常用功能实现

### 1. 文档内容操作

#### 插入文本
```javascript
function insertText(text, position = 'end') {
  try {
    const app = wps.WpsApplication()
    const doc = app.ActiveDocument
    
    if (position === 'cursor') {
      // 在光标位置插入
      app.Selection.TypeText(text)
    } else if (position === 'end') {
      // 在文档末尾插入
      const range = doc.Content
      range.Collapse(false) // 移动到末尾
      range.InsertAfter(text)
    }
  } catch (error) {
    console.error('插入文本失败:', error)
    throw error
  }
}
```

#### 查找和替换
```javascript
function findAndReplace(findText, replaceText) {
  try {
    const app = wps.WpsApplication()
    const doc = app.ActiveDocument
    
    const find = app.Selection.Find
    find.ClearFormatting()
    find.Text = findText
    find.Replacement.Text = replaceText
    
    // 执行全部替换
    find.Execute(
      findText,           // FindText
      false,             // MatchCase
      false,             // MatchWholeWord
      false,             // MatchWildcards
      false,             // MatchSoundsLike
      false,             // MatchAllWordForms
      true,              // Forward
      1,                 // Wrap (wdFindContinue)
      false,             // Format
      replaceText,       // ReplaceWith
      2                  // Replace (wdReplaceAll)
    )
  } catch (error) {
    console.error('查找替换失败:', error)
    throw error
  }
}
```

### 2. 文档格式化

#### 设置段落格式
```javascript
function formatParagraph(alignment = 'center') {
  try {
    const app = wps.WpsApplication()
    const selection = app.Selection
    
    // 设置对齐方式
    const alignmentMap = {
      'left': 0,    // wdAlignParagraphLeft
      'center': 1,  // wdAlignParagraphCenter
      'right': 2,   // wdAlignParagraphRight
      'justify': 3  // wdAlignParagraphJustify
    }
    
    selection.ParagraphFormat.Alignment = alignmentMap[alignment] || 1
  } catch (error) {
    console.error('段落格式化失败:', error)
    throw error
  }
}
```

#### 设置字体格式
```javascript
function formatFont(options = {}) {
  try {
    const app = wps.WpsApplication()
    const selection = app.Selection
    const font = selection.Font
    
    if (options.name) font.Name = options.name
    if (options.size) font.Size = options.size
    if (options.bold !== undefined) font.Bold = options.bold
    if (options.italic !== undefined) font.Italic = options.italic
    if (options.color) font.Color = options.color
  } catch (error) {
    console.error('字体格式化失败:', error)
    throw error
  }
}
```

### 3. 文件操作

#### 保存文档
```javascript
function saveDocument(fileName = null) {
  try {
    const app = wps.WpsApplication()
    const doc = app.ActiveDocument
    
    if (fileName) {
      doc.SaveAs(fileName)
    } else {
      doc.Save()
    }
    
    ElMessage.success('文档保存成功')
  } catch (error) {
    console.error('保存文档失败:', error)
    ElMessage.error('保存失败：' + error.message)
    throw error
  }
}
```

#### 导出为PDF
```javascript
function exportToPDF(outputPath) {
  try {
    const app = wps.WpsApplication()
    const doc = app.ActiveDocument
    
    // 导出为PDF格式
    doc.ExportAsFixedFormat(
      outputPath,        // OutputFileName
      17,               // ExportFormat (wdExportFormatPDF)
      false,            // OpenAfterExport
      0,                // OptimizeFor (wdExportOptimizeForPrint)
      1,                // Range (wdExportAllDocument)
      1,                // From
      1,                // To
      7,                // Item (wdExportDocumentContents)
      true,             // IncludeDocProps
      true,             // KeepIRM
      0,                // CreateBookmarks (wdExportCreateNoBookmarks)
      true,             // DocStructureTags
      true,             // BitmapMissingFonts
      false             // UseDocumentPrintSettings
    )
    
    ElMessage.success('PDF 导出成功')
  } catch (error) {
    console.error('PDF 导出失败:', error)
    ElMessage.error('导出失败：' + error.message)
    throw error
  }
}
```

