## 数据存储

### 使用 PluginStorage
```javascript
// 保存数据
function saveConfig(key, value) {
  try {
    const storage = wps.PluginStorage
    storage.setItem(key, JSON.stringify(value))
  } catch (error) {
    console.error('保存配置失败:', error)
  }
}

// 读取数据
function loadConfig(key, defaultValue = null) {
  try {
    const storage = wps.PluginStorage
    const value = storage.getItem(key)
    return value ? JSON.parse(value) : defaultValue
  } catch (error) {
    console.error('读取配置失败:', error)
    return defaultValue
  }
}

// 删除数据
function removeConfig(key) {
  try {
    const storage = wps.PluginStorage
    storage.removeItem(key)
  } catch (error) {
    console.error('删除配置失败:', error)
  }
}
```

## 错误处理最佳实践

### 1. WPS 环境检测
```javascript
function checkWPSEnvironment() {
  if (typeof wps === 'undefined') {
    ElMessage.warning('请在 WPS 环境中使用此功能')
    return false
  }
  
  try {
    const app = wps.WpsApplication()
    if (!app) {
      ElMessage.error('无法连接到 WPS 应用程序')
      return false
    }
    return true
  } catch (error) {
    console.error('WPS 环境检测失败:', error)
    ElMessage.error('WPS 环境异常')
    return false
  }
}
```

### 2. 统一错误处理装饰器
```javascript
function wpsApiWrapper(fn) {
  return async function(...args) {
    if (!checkWPSEnvironment()) {
      return null
    }
    
    try {
      return await fn.apply(this, args)
    } catch (error) {
      console.error(`WPS API 调用失败 [${fn.name}]:`, error)
      ElMessage.error(`操作失败: ${error.message}`)
      throw error
    }
  }
}

// 使用示例
const safeInsertText = wpsApiWrapper(insertText)
```

## 性能优化建议

### 1. 批量操作
```javascript
// 避免频繁的单次操作
function insertMultipleTexts(texts) {
  try {
    const app = wps.WpsApplication()
    const doc = app.ActiveDocument
    
    // 关闭屏幕更新以提高性能
    app.ScreenUpdating = false
    
    texts.forEach(text => {
      doc.Content.InsertAfter(text + '\n')
    })
    
    // 恢复屏幕更新
    app.ScreenUpdating = true
  } catch (error) {
    app.ScreenUpdating = true // 确保恢复
    throw error
  }
}
```

### 2. 对象引用缓存
```javascript
// 缓存常用对象引用
class WPSManager {
  constructor() {
    this.app = null
    this.doc = null
  }
  
  init() {
    this.app = wps.WpsApplication()
    this.doc = this.app.ActiveDocument
  }
  
  getSelection() {
    return this.app.Selection
  }
}

const wpsManager = new WPSManager()
```

