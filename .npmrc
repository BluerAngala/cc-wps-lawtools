# pnpm 配置文件
# 使用 pnpm 作为包管理器
package-manager=pnpm

# 设置存储路径
store-dir=node_modules/.pnpm

# 启用严格的对等依赖检查
strict-peer-dependencies=false

# 自动安装对等依赖
auto-install-peers=true

# 使用符号链接而不是复制文件
symlink=true

# 设置注册表 国内镜像
registry=https://registry.npmmirror.com/

# 启用 pnpm 的严格模式
strict-peer-dependencies=false
